# F.A.S.T — Agentic AI, RAG, and API configuration
# Copy to .env and fill in values

# LLM provider: openai | groq | gemini
LLM_PROVIDER=groq

OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# Leave blank to use provider default (gpt-4o-mini / llama-3.3-70b-versatile / gemini-2.0-flash)
LLM_MODEL=
LLM_TEMPERATURE=0.2
AGENT_MAX_ITERATIONS=8
ENABLE_LLM_AGENT=true

# RAG
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=./data/chroma
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=5

# Hugging Face Hub (RAG embeddings / gated model downloads)
HF_TOKEN=

# Chroma / ONNX protobuf compatibility
PROTOCOL_BUFFERS_PYTHON_IMPLEMENTATION=python

# API
API_HOST=0.0.0.0
API_PORT=8000
API_URL=http://localhost:8000

# X (Twitter) — social trends stream (OAuth1 recommended)
# X_API_KEY / X_API_SECRET are the consumer key pair from developer.x.com
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_AUTH_MODE=oauth1
X_STREAM_POLL_SECONDS=60
X_TWEET_LOOKBACK_DAYS=7

# Kafka — tweet ingestion pipeline
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_X_TWEETS_TOPIC=x-stock-tweets

# Paths (defaults use data/ layout — see README)
INFERENCE_DATA_DIR=./data/transcripts
SP500_CSV=./data/datasets/SP500.csv
